# ============================================
# Mirror Pupil v5.1 - Environment Configuration
# ============================================

# -----------------
# Telegram (Pytdbot/TDLib)
# -----------------
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# TDLib database encryption key (generate a random string)
TDLIB_ENCRYPTION_KEY=your_random_encryption_key_here

# TDLib files directory (where session data is stored)
TDLIB_FILES_DIR=./tdlib_data

# -----------------
# Database (Neon PostgreSQL)
# -----------------
# Get this from your Neon dashboard
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# -----------------
# Bot Configuration
# -----------------
# Dry-run mode (true = no real trades, false = live trading)
DRY_RUN=true

# Global lot size (default for all trades)
DEFAULT_LOT_SIZE=0.1

# Timezone for daily resets (5pm EST)
TIMEZONE=America/New_York

# -----------------
# Telegram Web App (TWA)
# -----------------
# Bot token for the TWA host bot (separate from the listening account)
# Get from @BotFather
BOT_TOKEN=your_bot_token_here

# HTTPS URL where the React app is served
WEBAPP_URL=https://your-domain.com

# -----------------
# API Server
# -----------------
# FastAPI server configuration
API_HOST=0.0.0.0
API_PORT=8000

# Secret key for JWT tokens (generate a random string)
API_SECRET_KEY=your_random_secret_key_here

# -----------------
# Firebase Authentication
# -----------------
# Path to Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_KEY=./firebase-service-account.json

# Disable auth for local development (true/false)
AUTH_DISABLED=false

# Dev mode user ID (used when AUTH_DISABLED=true)
DEV_USER_ID=dev-super-admin

# Super admin email (your Firebase account email)
SUPER_ADMIN_EMAIL=your-email@example.com

# -----------------
# Logging
# -----------------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./logs/mirror_pupil.log

# -----------------
# Anti-Ban Settings
# -----------------
# Human-like behavior delays (in seconds)
MIN_HUMAN_DELAY=0.5
MAX_HUMAN_DELAY=2.0

# Mark messages as read (true/false)
MARK_AS_READ=true

# Show typing indicator (true/false)
SHOW_TYPING=true

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# Reconnect settings
MAX_RECONNECT_ATTEMPTS=10
RECONNECT_BASE_DELAY=5
