# Mirror Pupil environment variables
# Copy to .env.local and adjust.

VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Set to "true" ONLY in development to render the UI with built-in mock data
# (no backend required). MUST be "false" or unset in production.
VITE_USE_MOCK=false